---
import fetchApi from '../../utils/strapi'
import type Post from '../../interfaces/Post'
import PageLayout from '../../layouts/PageLayout.astro'
import PostMeta from 'src/components/posts/PostMeta.astro'
import PostCard from 'src/components/posts/PostCard.astro'

export async function getStaticPaths() {
  const posts = await fetchApi<Post[]>({
    endpoint: 'posts',
    wrappedByKey: 'data',
  })

  return posts.map(post => ({
    params: { slug: post.attributes.slug },
    props: post,
  }))
}
type Props = Post

const post = Astro.props
---

<PageLayout>
  <!-- <PageMeta title={`Posts`} slot="meta" />  -->
  <PostMeta title={`Posts`} slot="meta" />
  <section slot="main">
    <h1>{post.attributes.title}</h1>
    <PostCard post={post} />
  </section>
</PageLayout>
